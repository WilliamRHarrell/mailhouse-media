# Mailhouse Media — Environment Variables
# Copy this to .env.local and fill in real values.

# ===== NEXT.JS =====
NEXT_PUBLIC_APP_URL=https://www.mailhousemedia.com

# ===== SUPABASE =====
# Get these from your Supabase project → Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...

# Server-side key (has full access — NEVER expose to client)
# Same Supabase project → Settings → API → service_role
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# ===== STRIPE =====
# Get these from https://dashboard.stripe.com/apikeys
# Use test keys during development, swap to live keys for prod
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# ===== STRIPE PRICES =====
# Create these in Stripe Dashboard → Products → Prices
# Format: price_xxxx (e.g. price_1Abc2...)

# EDDM 9x12 base price per home (unit-amount = $1.99)
STRIPE_PRICE_EDDM_9X12=price_REPLACE_ME

# AI Targeting service fee (flat, $99)
STRIPE_PRICE_AI_TARGETING=price_REPLACE_ME

# Custom design (flat, $150) — usually only first order < 2,500 homes
STRIPE_PRICE_DESIGN=price_REPLACE_ME

# ===== GHL (GoHighLevel) =====
# For lead sync / CRM notifications
GHL_API_KEY=
GHL_LOCATION_ID=Tf1GNxxLZVrbPq8HxDiC

# ===== N8N =====
# For order → fulfillment automation
N8N_WEBHOOK_URL=
